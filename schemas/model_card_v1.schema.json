{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mldlc-framework.org/schemas/model_card_v1.schema.json",
  "title": "Model Card",
  "description": "Schema for ML model documentation and transparency",
  "type": "object",
  "required": ["model_id", "version", "model_details", "model_parameters", "quantitative_analysis"],
  "properties": {
    "model_id": {"type": "string", "pattern": "^MODEL-[A-Z]{3}-[0-9]{6}$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "model_details": {
      "type": "object",
      "required": ["name", "description", "version", "owners"],
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string", "minLength": 100},
        "version": {"type": "string"},
        "owners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "contact": {"type": "string", "format": "email"},
              "role": {"type": "string"}
            }
          }
        },
        "license": {"type": "string"},
        "references": {"type": "array", "items": {"type": "string"}},
        "citation": {"type": "string"}
      }
    },
    "model_parameters": {
      "type": "object",
      "properties": {
        "model_architecture": {"type": "string"},
        "algorithm": {"type": "string"},
        "framework": {"type": "string"},
        "hyperparameters": {"type": "object"},
        "training_data": {
          "type": "object",
          "properties": {
            "dataset_id": {"type": "string"},
            "size": {"type": "integer"},
            "features": {"type": "integer"},
            "time_range": {"type": "string"},
            "preprocessing": {"type": "string"}
          }
        }
      }
    },
    "quantitative_analysis": {
      "type": "object",
      "properties": {
        "performance_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": {"type": "string"},
              "value": {"type": "number"},
              "split": {"type": "string", "enum": ["train", "validation", "test"]},
              "confidence_interval": {
                "type": "object",
                "properties": {
                  "lower": {"type": "number"},
                  "upper": {"type": "number"}
                }
              }
            }
          }
        },
        "benchmark_results": {"type": "object"}
      }
    },
    "ethical_considerations": {
      "type": "object",
      "properties": {
        "sensitive_data": {"type": "boolean"},
        "human_review_required": {"type": "boolean"},
        "fairness_assessment": {"type": "string"},
        "known_limitations": {"type": "array", "items": {"type": "string"}},
        "risk_factors": {"type": "array", "items": {"type": "string"}}
      }
    },
    "intended_use": {
      "type": "object",
      "properties": {
        "primary_use_cases": {"type": "array", "items": {"type": "string"}},
        "users": {"type": "array", "items": {"type": "string"}},
        "out_of_scope_uses": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
