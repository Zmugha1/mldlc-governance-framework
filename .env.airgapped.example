# Air-Gapped LLM Configuration with MoE Support
# Copy to .env.airgapped and configure

OLLAMA_URL=http://localhost:11434
HARDWARE_PROFILE=micro_team
AVAILABLE_VRAM_GB=24
PREFER_MOE=true
DEFAULT_MODEL_SIMPLE=phi3:mini
DEFAULT_MODEL_MEDIUM=qwen3.5:9b
DEFAULT_MODEL_COMPLEX=qwen3.5:35b-a3b
OLLAMA_EMBED_MODEL=nomic-embed-text
ENABLE_MODEL_ROUTING=true
ENABLE_STREAMING=true
ENABLE_MOE_ROUTING=true
CHROMA_PERSIST_DIR=./data/vector_db/chroma
