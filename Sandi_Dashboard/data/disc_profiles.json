  "S": {
    "name": "Steadiness",
    "traits": "Patient, loyal, supportive, team-oriented",
    "color": "#27AE60",
    "do": [
      "Build rapport slowly",
      "Provide stability and security",
      "Give them time to process",
      "Show genuine interest"
    ],
    "dont": [
